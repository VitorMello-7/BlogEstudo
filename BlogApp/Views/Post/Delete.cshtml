@model BlogApp.Models.Post

@{
    ViewData["Title"] = "Excluir Post";
}

<h1 class="mb-4 text-danger">Excluir Post</h1>

<div class="alert alert-warning">
    Tem certeza que deseja excluir este post? Esta ação não pode ser desfeita.
</div>

<dl class="row">
    <dt class="col-sm-2">Título</dt>
    <dd class="col-sm-10">@Model.Title</dd>

    <dt class="col-sm-2">Slug</dt>
    <dd class="col-sm-10"><code>@Model.Slug</code></dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>

    <dt class="col-sm-2">Criado em</dt>
    <dd class="col-sm-10">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
</dl>

<div class="d-flex gap-2">
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar exclusão</button>
    </form>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>
</div>
