@model BlogApp.Models.Post

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Voltar</a>
</div>

<div class="d-flex justify-content-between align-items-start mb-2">
    <h1>@Model.Title</h1>
    <span class="badge @(Model.Status == PostStatus.Published ? "bg-success" : Model.Status == PostStatus.Archived ? "bg-secondary" : "bg-warning text-dark") fs-6">
        @Model.Status
    </span>
</div>

<p class="text-muted">
    <small>
        Slug: <code>@Model.Slug</code> &nbsp;|&nbsp;
        Criado em: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
        @if (Model.PublishedAt.HasValue)
        {
            <span>&nbsp;|&nbsp; Publicado em: @Model.PublishedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        }
        @if (Model.UpdatedAt.HasValue)
        {
            <span>&nbsp;|&nbsp; Atualizado em: @Model.UpdatedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
        }
    </small>
</p>

@if (!string.IsNullOrEmpty(Model.Summary))
{
    <blockquote class="blockquote border-start ps-3 text-muted mb-3">
        @Model.Summary
    </blockquote>
}

@if (!string.IsNullOrEmpty(Model.CoverImageUrl))
{
    <img src="@Model.CoverImageUrl" alt="Capa" class="img-fluid mb-3 rounded" />
}

<div class="mt-3">
    @Html.Raw(Model.Content)
</div>

<hr />

<div class="d-flex gap-2 mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Editar</a>

    @if (Model.Status != PostStatus.Published)
    {
        <form asp-action="Publish" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-success">Publicar</button>
        </form>
    }

    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Excluir</a>
</div>
